# === БЫСТРЫЙ ВАРИАНТ: Groq (рекомендуется) ===
# Получите ключ на https://console.groq.com  (бесплатно — 2000 запросов/день)
# Скорость: ~0.3-0.7 сек на транскрипцию
GROQ_API_KEY=вставьте_ключ_здесь

# === РЕЗЕРВНЫЙ ВАРИАНТ: Deepgram ===
# Получите ключ на https://console.deepgram.com  (бесплатно — 200 часов/мес)
# Если GROQ_API_KEY задан — Deepgram не используется
DEEPGRAM_API_KEY=

# Клавиша для записи (удерживать).
# Рекомендуется: right ctrl, left windows, scroll lock, pause
# Символьные клавиши (space, запятая) вызывают флуд символов — не используйте
HOTKEY=right ctrl

# Секунд удержания до начала записи
HOLD_DELAY=1.0

# Минимальная длина записи в секундах
MIN_RECORD_SEC=0.5
