# Получите ключ на https://console.deepgram.com  (бесплатно — 200 часов/мес)
DEEPGRAM_API_KEY=вставьте_ключ_здесь

# Клавиша для записи (удерживать) — формат библиотеки keyboard
# Примеры: left windows | right windows | scroll lock | pause | f13
HOTKEY=left windows

# Минимальная длина записи в секундах (короткие случайные нажатия игнорируются)
MIN_RECORD_SEC=0.5
